# Centenarian Coach Multi-Agent — environment variables.
# Copy this file to .env.local and fill in the values. .env.local is gitignored.

# --- Anthropic: powers the supervisor + specialist agents ---
#   Get a key at https://console.anthropic.com  (Settings → API keys)
ANTHROPIC_API_KEY=

# --- Google Gemini: embeddings only (gemini-embedding-001 @ 768 dims) ---
#   Get a key at https://aistudio.google.com/apikey
#   GOOGLE_GEMINI_API_KEY is also accepted as an alias for this var.
GEMINI_API_KEY=

# --- Coach LLM provider: which model family answers questions ---
#   anthropic (default) = Claude (Sonnet 4.6 + Haiku 4.5)
#   google              = Gemini (2.5 Pro + 2.5 Flash)
#   Switch this to A/B the answer quality of each provider.
COACH_LLM_PROVIDER=anthropic

# --- Walkthrough video embed (optional) ---
#   The iframe-ready embed URL (e.g. https://www.youtube.com/embed/<id> or
#   https://player.vimeo.com/video/<id>). Shown on /walkthrough. When unset,
#   /walkthrough renders a "video coming soon" placeholder.
NEXT_PUBLIC_WALKTHROUGH_EMBED_URL=

# --- Email-link admin auth (Auth.js v5) ---
#   The single address allowed to sign in. Any other address is offered the
#   paid-access waitlist instead (no magic link is sent).
ADMIN_EMAIL=bam@awews.com
#   Same value exposed to the client so the /signin page can bifurcate before
#   triggering NextAuth. Just an email — not a secret.
NEXT_PUBLIC_ADMIN_EMAIL=bam@awews.com
#   Mailgun SMTP for magic-link delivery. Auth.js Nodemailer provider reads
#   EMAIL_SERVER as a connection string and EMAIL_FROM as the sender.
EMAIL_SERVER=
EMAIL_FROM="WitUS Inbox <forms@mg.witus.online>"
#   Mailgun extras — kept for parity with the witus ecosystem; not required
#   for magic links (those use EMAIL_SERVER via SMTP).
MAILGUN_DOMAIN=mg.witus.online
MAILGUN_API_KEY=
#   Cookie/JWT signing secret. Generate with: openssl rand -hex 32
#   Auth.js v5 reads AUTH_SECRET first and falls back to NEXTAUTH_SECRET.
NEXTAUTH_SECRET=

# --- Postgres (Neon): Drizzle migrations + pgvector retrieval ---
#   Neon provisioned via Vercel exposes this as STORAGE_DATABASE_URL.
#   A plain DATABASE_URL is also accepted by the code.
#   Get the connection string at https://neon.tech (your project → Connect).
STORAGE_DATABASE_URL=

# --- LangSmith: tracing (OPTIONAL) ---
#   Tracing is on by default, but the app runs fine without a key (fail-soft).
#   Get a key at https://smith.langchain.com (Settings → API keys).
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=centenarian-coach-multiagent
LANGSMITH_TRACING=true
