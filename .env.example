# Centenarian Coach Multi-Agent — environment variables.
# Copy this file to .env.local and fill in the values. .env.local is gitignored.

# --- LLM ---
# Seven providers are supported. Pick one (or stack a fallback chain).
#
#   FREE (rate-limited, $0):
#     OLLAMA       - local, no API key, just a reachable base URL.
#     CEREBRAS     - hosted free tier, Llama 3.3 70B, daily quota.
#     OPENROUTER   - hosted free models (DeepSeek, Qwen, Llama variants).
#     MISTRAL      - hosted free tier, 1B tokens/month.
#     TOGETHER     - hosted free tier, Llama 3.3 70B Turbo.
#
#   PAID (per-token billing) — keep as emergency fallback or quality runs:
#     ANTHROPIC    - Claude Sonnet 4.6 / Opus 4.7 / Haiku 4.5.
#     GOOGLE       - Gemini 2.5 Pro / Flash.
#
# Embeddings (gemini-embedding-001 @ 768 dims) ALWAYS use the Gemini key —
# the chat-model provider above does not affect retrieval.

# Paid (Claude / Gemini).
ANTHROPIC_API_KEY=               # https://console.anthropic.com
# GOOGLE_GEMINI_API_KEY and GOOGLE_API_KEY are also accepted as aliases.
GEMINI_API_KEY=                  # https://aistudio.google.com/apikey

# Free hosted tiers — sign up, paste keys.
CEREBRAS_API_KEY=                # https://cloud.cerebras.ai
OPENROUTER_API_KEY=              # https://openrouter.ai/keys
MISTRAL_API_KEY=                 # https://console.mistral.ai
TOGETHER_API_KEY=                # https://api.together.ai/settings/api-keys

# Local Ollama (no key). Override if running on a non-default host.
OLLAMA_BASE_URL=http://localhost:11434

# Force a provider (one of: ollama, cerebras, openrouter, mistral, together,
# anthropic, google). When unset, falls back to the stored dashboard setting,
# then to anthropic. Used by `pnpm eval` to pin the eval to one provider.
COACH_LLM_PROVIDER=anthropic

# Comma-separated fallback chain when the primary throws. Recommended for the
# deployed demo: openrouter,anthropic — OpenRouter catches Cerebras's daily
# quota, Anthropic catches anything that gets past OpenRouter as the paid
# emergency tier.
COACH_FALLBACK_PROVIDERS=

# --- Walkthrough video embed (optional) ---
#   The iframe-ready embed URL (e.g. https://www.youtube.com/embed/<id> or
#   https://player.vimeo.com/video/<id>). Shown on /walkthrough. When unset,
#   /walkthrough renders a "video coming soon" placeholder.
NEXT_PUBLIC_WALKTHROUGH_EMBED_URL=

# --- Email-link admin auth (Auth.js v5) ---
#   The single address allowed to sign in. Any other address is offered the
#   paid-access waitlist instead (no magic link is sent). The admin/waitlist
#   bifurcation happens server-side in /api/access-request — set this in your
#   server env (`.env.local` locally, Vercel project env in production).
ADMIN_EMAIL=bam@awews.com
#   Mailgun SMTP for magic-link delivery. Auth.js Nodemailer provider reads
#   EMAIL_SERVER as a connection string and EMAIL_FROM as the sender.
EMAIL_SERVER=
EMAIL_FROM="WitUS Inbox <forms@mg.witus.online>"
#   Mailgun extras — kept for parity with the witus ecosystem; not required
#   for magic links (those use EMAIL_SERVER via SMTP).
MAILGUN_DOMAIN=mg.witus.online
MAILGUN_API_KEY=
#   Cookie/JWT signing secret. Generate with: openssl rand -hex 32
#   Auth.js v5 reads AUTH_SECRET first and falls back to NEXTAUTH_SECRET.
NEXTAUTH_SECRET=

# --- WitUS Inbox — triage queue receiver (optional) ---
#   When set, every waitlist signup is mirrored to inbox.witus.online so it
#   appears in the central triage queue. Skipped if any of these is unset
#   (a dev-log fallback fires instead). BAM mints INBOX_INGEST_SECRET via
#   `openssl rand -hex 32` and installs the matching entry in the receiver's
#   INGEST_SOURCES.
INBOX_INGEST_URL=https://inbox.witus.online/api/ingest
INBOX_INGEST_SECRET=
INBOX_SOURCE_SLUG=centenarian-coach-multiagent

# --- Postgres (Neon): Drizzle migrations + pgvector retrieval ---
#   Neon provisioned via Vercel exposes this as STORAGE_DATABASE_URL.
#   A plain DATABASE_URL is also accepted by the code.
#   Get the connection string at https://neon.tech (your project → Connect).
STORAGE_DATABASE_URL=

# --- LangSmith: tracing (OPTIONAL) ---
#   Tracing is on by default, but the app runs fine without a key (fail-soft).
#   Get a key at https://smith.langchain.com (Settings → API keys).
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=centenarian-coach-multiagent
LANGSMITH_TRACING=true
