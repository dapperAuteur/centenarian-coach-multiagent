{
  "name": "centenarian-coach-multiagent",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "kb:seed": "node --env-file=.env.local scripts/seed-kb.mjs",
    "kb:clear": "node --env-file=.env.local scripts/clear-kb.mjs",
    "kb:ingest": "node --env-file=.env.local scripts/ingest-kb.mjs",
    "review": "node scripts/review.mjs",
    "eval": "RUN_EVALS=1 COACH_LLM_PROVIDER=google vitest run tests/coach.eval.test.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@base-ui/react": "^1.4.1",
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.47",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/langgraph": "^1.3.1",
    "@langchain/mistralai": "^1.1.0",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.7",
    "@neondatabase/serverless": "^1.1.0",
    "ai": "^6.0.185",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "langsmith": "^0.7.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "undici": "^8.3.0",
    "unpdf": "^1.3.2",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  }
}
